	[flake8]
max-line-length = 120
exclude =
    venv,
    .git,
    __pycache__,
    .pytest_cache,
    .github,
    .vscode,
    VINA_DTECH_APP,
    node_modules,
    alembic/versions,
    data,
    credentials,
    copilot-cli,
    gemini-cli

per-file-ignores =
    alembic/env.py: E402
    run_picker.py: E402
    run_picker_v2.py: E402
    scripts/check_config.py: E402
    scripts/init_db.py: E402
    bootstrap.py: E501
    tests/*: E402
    scripts/*: E402
