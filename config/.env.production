# ============================================
# PRODUCTION ENVIRONMENT
# ============================================

ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8010
WORKERS=4

# Security
API_TOKEN=AI_OS_SECRET_KEY_2026
SECRET_KEY=your-secret-key-here

# API Keys (Update with real keys)
OPENAI_API_KEY=your_openai_key_here
SHOPEE_PARTNER_ID=your_partner_id_here
SHOPEE_AFFILIATE_KEY=your_api_key_here

# Tracking
TRACKING_ID=AI_OS_V3
DEFAULT_MEDIUM=cps
DEFAULT_SOURCE=ai_os_kernel

# Database
CHROMA_DB_PATH=./chroma_data

# Affiliate
AFFILIATE_DB_PATH=./affiliate/affiliate.db
AUTO_SYNC_INTERVAL=3600

# Notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=
